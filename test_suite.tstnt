use math

test addition {
    assert_eq(1 + 1, 2)
    assert_eq(10 - 3, 7)
}

test multiplication {
    assert_eq(3 * 4, 12)
    assert_eq(10 / 2, 5)
}

test strings {
    assert_eq("hello" + " " + "world", "hello world")
    assert_eq(len("abc"), 3)
}

test arrays {
    let arr = [1, 2, 3]
    assert_eq(len(arr), 3)
    assert_eq(arr[0], 1)
}

test logic {
    assert(1 < 2)
    assert(2 > 1)
    assert(1 == 1)
    assert_ne(1, 2)
}

test math_funcs {
    assert_eq(math.abs(-5), 5)
    assert_eq(math.max(3, 7), 7)
    assert_eq(math.min(3, 7), 3)
}
